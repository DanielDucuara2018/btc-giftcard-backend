# Database Configuration
GIFTER_DB_HOST=localhost
GIFTER_DB_PORT=5432
GIFTER_DB_NAME=btcgifter
GIFTER_DB_USER=postgres
GIFTER_DB_PASSWORD=postgres
GIFTER_DB_SSL_MODE=disable
GIFTER_DB_MAX_CONNS=25
GIFTER_DB_MIN_CONNS=5
GIFTER_DB_MAX_CONN_LIFETIME=5
GIFTER_DB_MAX_CONN_IDLE_TIME=1

# Redis Configuration
GIFTER_REDIS_HOST=localhost
GIFTER_REDIS_PORT=6379
GIFTER_REDIS_PASSWORD=
GIFTER_REDIS_DB=0

# LND Configuration
GIFTER_LND_GRPC_HOST=localhost
GIFTER_LND_GRPC_PORT=10009
GIFTER_LND_TLS_CERT_PATH=
GIFTER_LND_MACAROON_PATH=
GIFTER_LND_NETWORK=testnet
GIFTER_LND_PAYMENT_TIMEOUT=30
GIFTER_LND_MAX_FEE_SATS=100

# Qonto configuration
# production:
# GIFTER_QONTO_BASE_URL=https://thirdparty.qonto.com/v2
# GIFTER_QONTO_LOGIN=
# GIFTER_QONTO_SECRET_KEY=
# GIFTER_QONTO_IBAN=
# GIFTER_QONTO_BIC=QNTOFRP1XXX
# GIFTER_QONTO_ORGANIZATION_SLUG=
# sandbox:
GIFTER_QONTO_BASE_URL=https://thirdparty-sandbox.staging.qonto.co/v2
GIFTER_QONTO_LOGIN=
GIFTER_QONTO_SECRET_KEY=
GIFTER_QONTO_IBAN=
GIFTER_QONTO_BIC=
GIFTER_QONTO_ORGANIZATION_SLUG=
GIFTER_QONTO_WEBHOOK_SECRET=
GIFTER_QONTO_STAGING_TOKEN=

# crypto.com Configuration
# production 
# GIFTER_CRYPTOCOM_BASE_URL=https://api.crypto.com/exchange/v1
# sandbox 
GIFTER_CRYPTOCOM_BASE_URL=https://uat-api.3ona.co/exchange/v1
GIFTER_CRYPTOCOM_API_KEY=
GIFTER_CRYPTOCOM_SECRET_KEY=
GIFTER_CRYPTOCOM_HTTP_TIMEOUT=15

# Treasury
GIFTER_TREASURY_CRYPTOCOM_IBAN=
GIFTER_TREASURY_CRYPTOCOM_NAME=
GIFTER_TREASURY_PURCHASE_FLOOR=1000000
GIFTER_TREASURY_PURCHASE_TARGET=500000

# Stripe
# production: use sk_live_xxx / pk_live_xxx after Stripe approval
GIFTER_STRIPE_SECRET_KEY=sk_test_xxx
GIFTER_STRIPE_PUBLIC_KEY=pk_test_xxx
GIFTER_STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frontend
GIFTER_FRONTEND_BASE_URL=http://localhost:3300
GIFTER_TREASURY_PURCHASE_TARGET=500000